{
  "mcpServers": {
    "kids_experience_radar": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "/ABSOLUTE/PATH/kids-experience-radar",
        "kidradar-mcp"
      ],
      "env": {
        "PYTHONUNBUFFERED": "1",
        "KIDS_RADAR_ENV_FILE": "/ABSOLUTE/PATH/kids-experience-radar/.env",
        "KIDS_RADAR_DB": "/ABSOLUTE/PATH/kids-experience-radar/data/radar.sqlite3",
        "KIDS_RADAR_MCP_ALLOW_CRAWL": "0"
      }
    }
  }
}
