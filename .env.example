# Full Seoul key is optional. Without it the official sample key returns 5 rows.
SEOUL_OPEN_DATA_KEY=

# Decoded service key issued by data.go.kr. Used by Culture Portal, national APIs,
# standard data, Jeonnam Art, and ODCloud connectors.
DATA_GO_KR_SERVICE_KEY=

# Separate key issued by the Shareeum (공유누리) OpenAPI portal.
ESHARE_API_KEY=

# Separate key issued by KOPIS. Used for performances classified as children's shows.
KOPIS_API_KEY=

# Optional venue-address geocoding. This key is never used for a user's live position.
KAKAO_REST_API_KEY=

# Comma-separated exact source IDs approved after policy/legal review.
KIDS_RADAR_APPROVED_SOURCES=

# Separate, documented operator acknowledgement for a source whose robots URL
# returns ambiguous non-robots HTML. Never use this for an explicit Disallow.
KIDS_RADAR_ROBOTS_OVERRIDE_SOURCES=

# Required before enabling HTML crawlers. Use a monitored operations address.
KIDS_RADAR_CONTACT=

# Optional read API configuration.
KIDS_RADAR_DB=data/radar.sqlite3
KIDS_RADAR_HOST=127.0.0.1
KIDS_RADAR_PORT=8080

# Local MCP is read-only unless both this gate and an exact source allowlist
# are configured in the MCP process environment.
KIDS_RADAR_MCP_ALLOW_CRAWL=0
KIDS_RADAR_MCP_CRAWL_SOURCES=

# Optional generic JSON webhook used by `kidradar digest`.
KIDS_RADAR_WEBHOOK_URL=
